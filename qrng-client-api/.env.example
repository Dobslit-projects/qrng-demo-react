# ── QRNG Client API — variáveis de ambiente ───────────────────────────────────
# Copie este arquivo para .env e ajuste os valores para seu ambiente.
# Em produção (systemd), configure as variáveis diretamente no arquivo de serviço.
# NUNCA commite o arquivo .env real — ele está no .gitignore.

# Porta em que a API escuta (padrão: 3010)
PORT=3010

# URL do QRNG upstream (FPGA/UFPE)
QRNG_UPSTREAM=http://127.0.0.1:18001

# Caminho do banco SQLite (padrão: ./qrng-tokens.db)
# DB_PATH=/var/data/qrng-tokens.db

# Segredo JWT — gere com: openssl rand -hex 32
# Obrigatório em produção. Se ausente, um valor aleatório é gerado a cada restart
# (invalida todas as sessões existentes).
JWT_SECRET=troque-por-um-valor-gerado-com-openssl-rand-hex-32

# E-mail do primeiro usuário admin.
# O usuário que se cadastrar com este e-mail recebe role=admin automaticamente.
ADMIN_EMAIL=admin@seudominio.com

# ── Limites de requisição ─────────────────────────────────────────────────────

# Tamanho máximo por requisição em bytes (padrão: 1 MiB = 1048576)
# Requisições acima retornam HTTP 413 REQUEST_TOO_LARGE.
MAX_BYTES_PER_REQUEST=1048576

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Máximo de requisições por minuto por IP (global, via express-rate-limit)
RATE_LIMIT_PER_IP_PER_MINUTE=120

# Máximo de requisições por minuto por token de API
RATE_LIMIT_PER_TOKEN_PER_MINUTE=60

# ── Cotas diárias ─────────────────────────────────────────────────────────────

# Cota padrão de requests por dia por token (usada ao criar novos tokens)
# Pode ser ajustada por token individualmente via PATCH /v1/admin/tokens/:id/quota
DAILY_QUOTA_REQUESTS=10000

# Cota máxima de bytes por dia por token (global, aplica a todos os tokens)
# 100 MiB = 104857600
DAILY_QUOTA_BYTES=104857600

# ── Timeout do upstream ───────────────────────────────────────────────────────

# Timeout em ms para chamadas ao QRNG upstream (padrão: 10000 = 10s)
QRNG_REQUEST_TIMEOUT_MS=10000
